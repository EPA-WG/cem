@doc cem-ml 1
@ns cem = "https://cem.dev/ns/core/1"
@ns html = "http://www.w3.org/1999/xhtml"
@default html

/* conversion fixture */
{main @cem:screen=conversion @aria-labelledby=title |
  {h1 @id=title | Conversion fixture}
  {section @xmlns="http://www.w3.org/2000/svg" |
    {path @d="M2 8h12"}
  }
  {@type="application/json" |
```{"name":"{$.user}","ok":true}```
  }
  {$ | .items[0].name}
  {button @disabled={.busy} @aria-label="Hello {.name}" | Save}
}
