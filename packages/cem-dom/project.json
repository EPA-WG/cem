{
    "name": "@epa-wg/cem-dom",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/cem-dom/src",
    "projectType": "library",
    "tags": ["scope:cem-dom", "type:lib"],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "tsc --build tsconfig.lib.json",
                "cwd": "packages/cem-dom"
            },
            "cache": true,
            "inputs": ["production", "{projectRoot}/package.json"],
            "outputs": ["{projectRoot}/dist"]
        },
        "typecheck": {
            "executor": "nx:run-commands",
            "options": {
                "commands": ["tsc --project tsconfig.lib.json --noEmit", "tsc --project tsconfig.spec.json --noEmit"],
                "parallel": true,
                "cwd": "packages/cem-dom"
            },
            "cache": true,
            "inputs": ["default"],
            "outputs": []
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "eslint .",
                "cwd": "packages/cem-dom"
            },
            "cache": true,
            "inputs": ["default"],
            "outputs": []
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node --test --experimental-test-coverage src/lib/cem-dom.test.ts src/cli.test.ts",
                "cwd": "packages/cem-dom"
            },
            "cache": true,
            "inputs": ["default"],
            "outputs": []
        },
        "validate-fixtures": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node packages/cem-dom/scripts/validate-fixtures.ts",
                "cwd": "."
            },
            "cache": true,
            "inputs": ["{projectRoot}/src/**/*.ts", "{projectRoot}/scripts/**/*.ts", "{workspaceRoot}/examples/semantic/*.html"],
            "outputs": ["{projectRoot}/dist/cem-dom.report.md", "{projectRoot}/dist/cem-dom.report.json"]
        }
    }
}
