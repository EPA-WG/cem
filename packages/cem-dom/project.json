{
    "name": "@epa-wg/cem-dom",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/cem-dom/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "commands": [
                    "tsc --build tsconfig.lib.json",
                    "node scripts/validate-fixtures.mjs"
                ],
                "parallel": false,
                "cwd": "packages/cem-dom"
            },
            "cache": true,
            "inputs": [
                "production",
                "{projectRoot}/src/**/*.ts",
                "{projectRoot}/scripts/validate-fixtures.mjs",
                "{workspaceRoot}/examples/semantic/*.html"
            ],
            "outputs": [
                "{projectRoot}/dist"
            ]
        },
        "build:docs": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node ../../tools/scripts/compile-markdown.mjs --project .",
                "cwd": "packages/cem-dom"
            },
            "cache": true,
            "inputs": [
                "{projectRoot}/src/**/*.md"
            ],
            "outputs": [
                "{projectRoot}/dist/**/*.md",
                "{projectRoot}/dist/**/*.xhtml"
            ]
        },
        "validate-fixtures": {
            "executor": "nx:run-commands",
            "options": {
                "command": "node scripts/validate-fixtures.mjs",
                "cwd": "packages/cem-dom"
            },
            "dependsOn": ["build"],
            "cache": true,
            "inputs": [
                "{projectRoot}/scripts/validate-fixtures.mjs",
                "{workspaceRoot}/examples/semantic/*.html",
                "{projectRoot}/dist/index.js"
            ],
            "outputs": [
                "{projectRoot}/dist/cem-dom.report.md",
                "{projectRoot}/dist/cem-dom.report.json"
            ]
        }
    }
}
