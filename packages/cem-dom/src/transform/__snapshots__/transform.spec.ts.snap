// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`transform — snapshot each fixture > assets-list.html matches snapshot 1`] = `"<!DOCTYPE doctype html><html lang="en"><head><meta charset="utf-8"><title>CEM Semantic Fixture - Assets List</title></head><body><cem-screen cem-id="assets" aria-labelledby="assets-title"><h1 id="assets-title">Assets</h1><cem-form cem-id="asset-filter" role="search"><label for="asset-query">Search assets</label><input id="asset-query" name="q" type="search"><cem-action variant="secondary" type="submit">Search</cem-action></cem-form><cem-list cem-id="assets"><cem-row cem-id="asset"><a href="/assets/1001">Design token report</a><cem-badge variant="info">PDF</cem-badge></cem-row><cem-row cem-id="asset"><a href="/assets/1002">Theme export bundle</a><cem-badge variant="success">JSON</cem-badge></cem-row></cem-list></cem-screen></body></html>"`;

exports[`transform — snapshot each fixture > login.html matches snapshot 1`] = `"<!DOCTYPE doctype html><html lang="en"><head><meta charset="utf-8"><title>CEM Semantic Fixture - Login</title></head><body><cem-screen cem-id="login" aria-labelledby="login-title"><h1 id="login-title">Sign in</h1><cem-form cem-id="sign-in" method="post" action="/session"><label for="email">Email</label><input id="email" name="email" type="email" autocomplete="email" required><label for="password">Password</label><input id="password" name="password" type="password" autocomplete="current-password" required><cem-action variant="primary" type="submit">Sign in</cem-action></cem-form></cem-screen></body></html>"`;

exports[`transform — snapshot each fixture > message-thread.html matches snapshot 1`] = `"<!DOCTYPE doctype html><html lang="en"><head><meta charset="utf-8"><title>CEM Semantic Fixture - Message Thread</title></head><body><cem-screen cem-id="message-thread" aria-labelledby="thread-title"><h1 id="thread-title">Support thread</h1><cem-thread cem-id="support"><cem-message variant="received"><p><strong>Support</strong></p><p>Your export is ready for review.</p></cem-message><cem-message variant="sent"><p><strong>You</strong></p><p>I will compare it with the Figma token page.</p></cem-message></cem-thread><cem-form cem-id="message-reply" method="post" action="/thread/reply"><label for="reply">Reply</label><textarea id="reply" name="reply" rows="4" required></textarea><cem-action variant="primary" type="submit">Send</cem-action></cem-form></cem-screen></body></html>"`;

exports[`transform — snapshot each fixture > profile.html matches snapshot 1`] = `"<!DOCTYPE doctype html><html lang="en"><head><meta charset="utf-8"><title>CEM Semantic Fixture - Profile</title></head><body><cem-screen cem-id="profile" aria-labelledby="profile-title"><h1 id="profile-title">Profile</h1><cem-card cem-id="identity" aria-labelledby="identity-title"><h2 id="identity-title">Identity</h2><dl><dt>Name</dt><dd>Alex Carter</dd><dt>Email</dt><dd>alex@example.test</dd><dt>Status</dt><dd><cem-badge variant="success">Verified</cem-badge></dd></dl></cem-card><cem-card cem-id="preferences" aria-labelledby="preferences-title"><h2 id="preferences-title">Preferences</h2><cem-form cem-id="profile-preferences"><label><input name="email_updates" type="checkbox" checked>Email updates</label><cem-action variant="secondary" type="submit">Save preferences</cem-action></cem-form></cem-card></cem-screen></body></html>"`;

exports[`transform — snapshot each fixture > registration.html matches snapshot 1`] = `"<!DOCTYPE doctype html><html lang="en"><head><meta charset="utf-8"><title>CEM Semantic Fixture - Registration</title></head><body><cem-screen cem-id="registration" aria-labelledby="registration-title"><h1 id="registration-title">Create account</h1><cem-form cem-id="registration" method="post" action="/account"><label for="name">Full name</label><input id="name" name="name" autocomplete="name" required><label for="email">Email</label><input id="email" name="email" type="email" autocomplete="email" required><label for="password">Password</label><input id="password" name="password" type="password" autocomplete="new-password" required><label><input name="terms" type="checkbox" required>I agree to the terms</label><cem-action variant="primary" type="submit">Create account</cem-action></cem-form></cem-screen></body></html>"`;
