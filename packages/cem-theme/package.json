{
    "name": "@epa-wg/cem-theme",
    "version": "0.0.10",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/EPA-WG/cem.git",
        "directory": "packages/cem-theme"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "@epa-wg/cem": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./tokens/cem.tokens.json": "./dist/lib/tokens/cem.tokens.json",
        "./tokens/cem.voice.tokens.json": "./dist/lib/tokens/cem.voice.tokens.json",
        "./tokens/cem.tokens.report.json": "./dist/lib/tokens/cem.tokens.report.json",
        "./tokens/cem.tokens.ts": "./dist/lib/tokens/cem.tokens.ts",
        "./tokens/figma/*": "./dist/lib/tokens/figma/*"
    },
    "files": [
        "dist",
        "!**/*.tsbuildinfo"
    ],
    "scripts": {
        "build:html": "node ../../tools/scripts/compile-html.mjs",
        "build:css": "node ../../tools/scripts/compile-html.mjs && node ../../tools/scripts/capture-xpath-text.mjs \"dist/lib/css-generators/cem-*.html\" \"//code[@data-generated-css]\" \"dist/lib/css/*.css\" && node scripts/generate-token-coverage.mjs && node scripts/generate-css-index.mjs",
        "build:tokens": "node scripts/export-tokens.mjs"
    },
    "devDependencies": {
        "chokidar": "5.0.0",
        "glob": "13.0.6",
        "markdown-it": "14.1.1",
        "markdown-it-anchor": "9.2.0",
        "playwright": "1.59.1",
        "postcss": "8.5.12"
    },
    "publishConfig": {
        "access": "public"
    }
}
