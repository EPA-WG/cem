{
    "name": "cem_ml_cli",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "packages/cem_ml_cli/src",
    "targets": {
        "build": {
            "cache": true,
            "executor": "@monodon/rust:build",
            "outputs": ["{options.target-dir}"],
            "options": {
                "package": "cem-ml-cli",
                "target-dir": "dist/target/cem_ml_cli"
            },
            "configurations": {
                "production": {
                    "release": true
                }
            }
        },
        "test": {
            "cache": true,
            "executor": "@monodon/rust:test",
            "outputs": ["{options.target-dir}"],
            "options": {
                "package": "cem-ml-cli",
                "target-dir": "dist/target/cem_ml_cli"
            },
            "configurations": {
                "production": {
                    "release": true
                }
            }
        },
        "lint": {
            "cache": true,
            "executor": "@monodon/rust:lint",
            "outputs": ["{options.target-dir}"],
            "options": {
                "package": "cem-ml-cli",
                "target-dir": "dist/target/cem_ml_cli"
            }
        },
        "run": {
            "executor": "@monodon/rust:run",
            "outputs": ["{options.target-dir}"],
            "options": {
                "package": "cem-ml-cli",
                "target-dir": "dist/target/cem_ml_cli"
            },
            "configurations": {
                "production": {
                    "release": true
                }
            }
        },
        "validate-fixtures": {
            "executor": "nx:run-commands",
            "dependsOn": ["build"],
            "options": {
                "command": "./dist/target/cem_ml_cli/debug/cem-ml fixture validate --zero-hard-violations --report-json packages/cem_ml_cli/dist --report-md packages/cem_ml_cli/dist",
                "cwd": "{workspaceRoot}"
            },
            "inputs": [
                "{projectRoot}/src/**/*.rs",
                "{projectRoot}/Cargo.toml",
                "{workspaceRoot}/packages/cem_ml/src/**/*.rs",
                "{workspaceRoot}/packages/cem_ml/Cargo.toml",
                "{workspaceRoot}/examples/cem-ml/**/*.cem",
                "{workspaceRoot}/examples/semantic/**/*.html"
            ],
            "outputs": [
                "{projectRoot}/dist/cem-ml.report.json",
                "{projectRoot}/dist/cem-ml.report.md"
            ]
        }
    },
    "tags": ["scope:cem-ml", "type:app", "lang:rust"]
}
