{
  "name": "@epa-wg/cem",
  "description": "Consumer Semantic Material Theme and custom-element components library for NO-JS declarative web applications.",
  "version": "0.0.14",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/EPA-WG/cem.git"
  },
  "scripts": {
    "rebuild": "yarn build:clean; yarn build",
    "build": "nx run-many -t build && nx run cem_ml_cli:validate-fixtures",
    "build:clean": "nx reset; rm -rf packages/cem-theme/dist; rm -rf packages/cem-components/dist; rm -rf packages/cem-elements/dist",
    "build:theme": "nx run @epa-wg/cem-theme:build",
    "build:css": "nx run @epa-wg/cem-theme:build:css",
    "lint": "nx run-many -t lint",
    "publish:prepare": "./tools/scripts/publish-prepare.sh",
    "validate:utf8": "node tools/scripts/validate-utf8.mjs",
    "css-generate": "node tools/scripts/capture-xpath-text.mjs file://./packages/cem-theme/src/lib/css-generators/colors.html //*[@code='language-css'] /tmp/colors.css",
    "start": "node tools/scripts/dev-server.mjs"
  },
  "dependencies": {
    "@epa-wg/custom-element": "workspace:^"
  },
  "devDependencies": {
    "@epa-wg/trang-native": "workspace:^",
    "@eslint/js": "10.0.1",
    "@monodon/rust": "^2.3.0",
    "@nx/eslint": "22.7.0",
    "@nx/eslint-plugin": "22.7.0",
    "@nx/js": "22.7.0",
    "@nx/vitest": "22.7.0",
    "@storybook/addon-vitest": "10.4.2",
    "@storybook/web-components-vite": "10.4.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.32",
    "@swc/helpers": "0.5.21",
    "@types/node": "25.6.0",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "ajv": "8.18.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "jsonc-eslint-parser": "3.1.0",
    "lit": "3.3.3",
    "nx": "22.7.0",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "storybook": "10.4.2",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "verdaccio": "6.5.2",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "workspaces": [
    "packages/*"
  ],
  "web-types": [
    "./packages/custom-element/ide/web-types-dce.json",
    "./packages/custom-element/ide/web-types-xsl.json",
    "./web_types.json"
  ],
  "packageManager": "yarn@4.12.0",
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      },
      "fitness-removal-scan": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "command": "node tools/scripts/ff-deprecated-form-scan.mjs",
          "cwd": "{workspaceRoot}"
        },
        "inputs": [
          "{workspaceRoot}/tools/scripts/ff-deprecated-form-scan.mjs",
          "{workspaceRoot}/tools/fitness/lib.mjs",
          "{workspaceRoot}/tools/fitness/deprecated-forms.json",
          "{workspaceRoot}/packages/**/*.{ts,js,mjs,html,cem}",
          "{workspaceRoot}/examples/**/*.{ts,js,mjs,html,cem}"
        ],
        "outputs": []
      },
      "fitness-semver-presence": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "command": "node tools/scripts/ff-semver-presence.mjs",
          "cwd": "{workspaceRoot}"
        },
        "inputs": [
          "{workspaceRoot}/tools/scripts/ff-semver-presence.mjs",
          "{workspaceRoot}/tools/fitness/lib.mjs",
          "{workspaceRoot}/tools/fitness/governed-contracts.json",
          "{workspaceRoot}/packages/*/package.json",
          "{workspaceRoot}/packages/*/Cargo.toml",
          "{workspaceRoot}/packages/cem-elements/src/**/*.ts",
          "{workspaceRoot}/packages/cem-theme/dist/lib/tokens/*.json"
        ],
        "outputs": []
      },
      "fitness-gate-map": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "command": "node tools/scripts/ff-gate-run.mjs",
          "cwd": "{workspaceRoot}"
        },
        "inputs": [
          "{workspaceRoot}/tools/scripts/ff-gate-run.mjs",
          "{workspaceRoot}/tools/fitness/fitness-gates.json",
          "{workspaceRoot}/.github/workflows/ci.yml",
          "{workspaceRoot}/packages/*/project.json",
          "{workspaceRoot}/package.json",
          "{workspaceRoot}/examples/cem-ml/**/*",
          "{workspaceRoot}/tools/fitness/*.json",
          "{workspaceRoot}/tools/scripts/ff-*.mjs"
        ],
        "outputs": []
      }
    }
  }
}
